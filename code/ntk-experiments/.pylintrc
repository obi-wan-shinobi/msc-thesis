[MASTER]
py-version=3.10

[MESSAGES CONTROL]
enable=invalid-name

[BASIC]
variable-rgx=^([a-z_][a-z0-9_]*|[A-Z](?:_[a-z0-9]+)*)$
argument-rgx=^([a-z_][a-z0-9_]*|[A-Z](?:_[a-z0-9]+)*)$
attr-rgx=^([a-z_][a-z0-9_]*|[A-Z](?:_[a-z0-9]+)*)$

function-rgx=^[a-z_][a-z0-9_]*$
method-rgx=^[a-z_][a-z0-9_]*$
const-rgx=^([A-Z_][A-Z0-9_]*)$
class-rgx=^[A-Z][a-zA-Z0-9]+$
module-rgx=^[a-z_][a-z0-9_]*$
